# =============================================================================
# KICS Configuration File
# =============================================================================
# This configuration defines exclusions for the KICS (Keeping Infrastructure
# as Code Secure) scanner. Only verified false positives and intentional
# configurations with documented compensating controls are excluded.
#
# Policy: ZERO-TOLERANCE with documented exceptions only.
# All entries must be reviewed and approved by the security team.
#
# Documentation: https://docs.kics.io/latest/configuration-file/
# =============================================================================

exclude-queries:

  # ===========================================================================
  # Kubernetes: Container Security Context
  # ===========================================================================
  # Per-container justification for running as root (UID 0):
  #   - openemr: upstream image runs Apache/PHP-FPM as root; requires SETUID,
  #     SETGID, CHOWN, FOWNER, DAC_OVERRIDE for process management and file ops
  #   - fluent-bit-sidecar: reads host log files owned by root; needs UID 0
  #     for /var/log access and DAC_READ_SEARCH capability
  #   - credential-rotation: writes to EFS-mounted sqlconf.php (root-owned);
  #     needs CHOWN, FOWNER, DAC_OVERRIDE for atomic file replacement
  #   - ssl-renewal: runs certbot which requires root for /etc/letsencrypt
  #   - warp test/benchmark: run apt-get and pip install at runtime (batch jobs)
  # Compensating controls: capabilities drop ALL then add back minimum set,
  # seccompProfile: RuntimeDefault on all pods, namespace-scoped RBAC,
  # network policies restrict egress, ttlSecondsAfterFinished on Jobs.
  # Cross-ref: .trivyignore AVD-KSV-0001, AVD-KSV-0012, AVD-KSV-0020,
  # AVD-KSV-0105, AVD-KSV-0116.
  # ===========================================================================

  # Privilege Escalation Allowed
  # Applies to: openemr container only (SETUID/SETGID for Apache child procs)
  # https://docs.kics.io/latest/queries/kubernetes-queries/5572cc5e-1e4c-4113-92a6-7a8a3bd25e6d/
  - "5572cc5e-1e4c-4113-92a6-7a8a3bd25e6d"

  # Container Running As Root
  # Applies to: openemr, fluent-bit, credential-rotation, ssl-renewal, warp jobs
  # https://docs.kics.io/latest/queries/kubernetes-queries/cf34805e-3872-4c08-bf92-6ff7bb0cfadb/
  - "cf34805e-3872-4c08-bf92-6ff7bb0cfadb"

  # Container Running With Low UID
  # Applies to: same containers as above — all run as UID 0
  # https://docs.kics.io/latest/queries/kubernetes-queries/02323c00-cdc3-4fdc-a310-4f2b3e7a1660/
  - "02323c00-cdc3-4fdc-a310-4f2b3e7a1660"

  # Root Container Not Mounted Read-only
  # Applies to: openemr (PHP sessions/logs), fluent-bit (log buffers),
  # ssl-renewal (certbot), warp test/benchmark (apt-get/pip)
  # https://docs.kics.io/latest/queries/kubernetes-queries/a9c2f49d-0671-4fc9-9ece-f4e261e128d0/
  - "a9c2f49d-0671-4fc9-9ece-f4e261e128d0"

  # Missing AppArmor Profile
  # Applies to: all pods
  # Reason: AppArmor is not enabled on our Bottlerocket node AMI. Runtime
  # isolation is provided by seccompProfile: RuntimeDefault on all pods and
  # Bottlerocket's built-in SELinux policies + dm-verity + read-only root FS.
  # https://docs.kics.io/latest/queries/kubernetes-queries/8b36775e-183d-4d46-b0f7-96a6f34a723f/
  # https://github.com/bottlerocket-os/bottlerocket/blob/develop/SECURITY_FEATURES.md
  - "8b36775e-183d-4d46-b0f7-96a6f34a723f"

  # ===========================================================================
  # Kubernetes: Container Capabilities
  # ===========================================================================
  # All long-running containers (openemr, fluent-bit) and Jobs (credential-
  # rotation, ssl-renewal) drop ALL capabilities then add back only what's
  # needed. Warp test/benchmark jobs do not drop caps because they install
  # system packages at runtime via apt-get (batch jobs with ttlSecondsAfter-
  # Finished; not long-running services).
  # ===========================================================================

  # Containers With Added Capabilities
  # Applies to: openemr (NET_BIND_SERVICE, CHOWN, SETUID, SETGID, FOWNER,
  # DAC_OVERRIDE), fluent-bit (DAC_READ_SEARCH), credential-rotation
  # (CHOWN, FOWNER, DAC_OVERRIDE), ssl-renewal (CHOWN, FOWNER)
  # https://docs.kics.io/latest/queries/kubernetes-queries/19ebaa28-fc86-4a58-bcfa-015c9e22fe40/
  - "19ebaa28-fc86-4a58-bcfa-015c9e22fe40"

  # No Drop Capabilities for Containers
  # Applies to: warp test/benchmark jobs (batch jobs that apt-get install at runtime)
  # https://docs.kics.io/latest/queries/kubernetes-queries/268ca686-7fb7-4ae9-b129-955a2a89064e/
  - "268ca686-7fb7-4ae9-b129-955a2a89064e"

  # NET_RAW Capabilities Not Being Dropped
  # Applies to: warp test/benchmark jobs — these do not drop ALL caps (see above),
  # so NET_RAW remains in the default set. NET_RAW itself is not required; this
  # is a side effect of not dropping ALL. Long-term fix: build deps into image.
  # https://docs.kics.io/latest/queries/kubernetes-queries/dbbc6705-d541-43b0-b166-dd4be8208b54/
  - "dbbc6705-d541-43b0-b166-dd4be8208b54"

  # ===========================================================================
  # Kubernetes: Volume and HostPath Mounts
  # ===========================================================================
  # Applies to: fluent-bit sidecar in k8s/deployment.yaml only.
  # Fluent Bit mounts /proc and /sys for the node_exporter_metrics input
  # plugin (CPU, memory, disk, network metrics).
  # Both mounts specify readOnly: true; mountPropagation defaults to None.
  # OpenEMR mounts EFS-backed PVCs (not hostPath) to /etc/ssl and
  # /etc/letsencrypt for TLS certificate management via certbot.
  # Compensating controls: fluent-bit runs with allowPrivilegeEscalation:
  # false, drops ALL caps then adds only DAC_READ_SEARCH, seccompProfile:
  # RuntimeDefault, network policies restrict egress.
  # ===========================================================================

  # Volume Mount With OS Directory Write Permissions
  # Applies to: openemr container (/etc/ssl, /etc/letsencrypt PVC mounts)
  # https://docs.kics.io/latest/queries/kubernetes-queries/b7652612-de4e-4466-a0bf-1cd81f0c6063/
  - "b7652612-de4e-4466-a0bf-1cd81f0c6063"

  # Non Kube System Pod With Host Mount
  # Applies to: fluent-bit sidecar (/proc, /sys hostPath — readOnly: true)
  # https://docs.kics.io/latest/queries/kubernetes-queries/aa8f7a35-9923-4cad-bd61-a19b7f6aac91/
  - "aa8f7a35-9923-4cad-bd61-a19b7f6aac91"

  # Workload Mounting With Sensitive OS Directory
  # Applies to: fluent-bit sidecar (/proc, /sys hostPath — readOnly: true)
  # https://docs.kics.io/latest/queries/kubernetes-queries/5308a7a8-06f8-45ac-bf10-791fe21de46e/
  - "5308a7a8-06f8-45ac-bf10-791fe21de46e"

  # ===========================================================================
  # Kubernetes: Secrets and RBAC
  # ===========================================================================
  # Secrets are injected via secretKeyRef env vars (standard EKS pattern).
  # EKS envelope encryption is enabled with a customer-managed KMS key
  # (aws_kms_key.eks in terraform/kms.tf), so Secrets are encrypted at rest.
  # RBAC roles are namespace-scoped with specific resourceNames.
  # ===========================================================================

  # Secrets As Environment Variables
  # Applies to: openemr (DB, Redis, app creds), warp jobs (DB creds),
  # credential-rotation (inherits via Secrets Manager, not env vars)
  # Compensating controls: KMS envelope encryption at rest, RBAC scoped to
  # openemr namespace, no interactive shell access, audit logging enabled
  # https://docs.kics.io/latest/queries/kubernetes-queries/3d658f8b-d988-41a0-a841-40043121de1e/
  - "3d658f8b-d988-41a0-a841-40043121de1e"

  # Using Kubernetes Native Secret Management
  # Applies to: k8s/secrets.yaml (DB, Redis, app, TLS secrets)
  # Reason: K8s Secrets with KMS envelope encryption are sufficient for the
  # current threat model. Migrating to AWS Secrets Manager CSI driver is a
  # documented future improvement.
  # https://docs.kics.io/latest/queries/kubernetes-queries/b9c83569-459b-4110-8f79-6305aa33cb37/
  - "b9c83569-459b-4110-8f79-6305aa33cb37"

  # ServiceAccount Allows Access Secrets
  # Applies to: credential-rotation-sa (get/update/patch on openemr-db-credentials),
  # openemr-sa (get/list on configmaps and secrets)
  # Both roles are namespace-scoped with explicit resourceNames.
  # https://docs.kics.io/latest/queries/kubernetes-queries/056ac60e-fe07-4acc-9b34-8e1d51716ab9/
  - "056ac60e-fe07-4acc-9b34-8e1d51716ab9"

  # RBAC Roles with Read Secrets Permissions
  # Applies to: same roles as above — namespace-scoped, specific resourceNames
  # https://docs.kics.io/latest/queries/kubernetes-queries/b7bca5c4-1dab-4c2c-8cbe-3050b9d59b14/
  - "b7bca5c4-1dab-4c2c-8cbe-3050b9d59b14"

  # Shared Service Account
  # Applies to: openemr-sa (used by openemr Deployment, ssl-renewal, warp jobs)
  # Reason: all share one IRSA role needing S3 + EFS + CloudWatch access.
  # credential-rotation-sa is a separate SA with its own IRSA role.
  # Lateral movement prevention: NetworkPolicies restrict pod-to-pod traffic,
  # no kubectl exec allowed, RBAC denies create/delete on pods.
  # https://docs.kics.io/latest/queries/kubernetes-queries/c1032cf7-3628-44e2-bd53-38c17cf31b6b/
  - "c1032cf7-3628-44e2-bd53-38c17cf31b6b"

  # Service Account Token Automount Not Disabled
  # Applies to: openemr-sa, credential-rotation-sa
  # Reason: IRSA requires projected bound service account tokens with audience
  # sts.amazonaws.com and short expiration. These are not legacy static tokens.
  # automountServiceAccountToken: true is required for the AWS SDK to obtain
  # credentials via the projected volume at /var/run/secrets/eks.amazonaws.com/.
  # https://docs.kics.io/latest/queries/kubernetes-queries/48471392-d4d0-47c0-b135-cdec95eb3eef/
  - "48471392-d4d0-47c0-b135-cdec95eb3eef"

  # ===========================================================================
  # Kubernetes: Image and Deployment Configuration
  # ===========================================================================
  # Images use envsubst placeholders (${OPENEMR_VERSION}) resolved at deploy
  # time by scripts/deploy.sh. IfNotPresent pull policy avoids redundant pulls
  # for version-pinned images. HPA manages scaling after leader pod startup.
  # ===========================================================================

  # Invalid Image Tag
  # Applies to: credential-rotation (${CREDENTIAL_ROTATION_IMAGE} envsubst),
  # warp/k8s-job.yaml (:latest — user-facing template, not deployed directly)
  # https://docs.kics.io/latest/queries/kubernetes-queries/583053b7-e632-46f0-b989-f81ff8045385/
  - "583053b7-e632-46f0-b989-f81ff8045385"

  # Image Without Digest
  # Applies to: all K8s manifests — tags resolved by envsubst at deploy time
  # https://docs.kics.io/latest/queries/kubernetes-queries/7c81d34c-8e5a-402b-9798-9f442630e678/
  - "7c81d34c-8e5a-402b-9798-9f442630e678"

  # Image Pull Policy Of The Container Is Not Set To Always
  # Applies to: openemr, fluent-bit, ssl-renewal containers
  # Reason: IfNotPresent avoids redundant image pulls for pinned version tags
  # https://docs.kics.io/latest/queries/kubernetes-queries/caa3479d-885d-4882-9aac-95e5e78ef5c2/
  - "caa3479d-885d-4882-9aac-95e5e78ef5c2"

  # HPA Targeted Deployments With Configured Replica Count
  # Applies to: k8s/deployment.yaml (replicas: 1)
  # Reason: OpenEMR's docker-leader container must initialize alone before
  # HPA scales to minReplicas. HPA does not break this because it will not
  # scale below minReplicas once the leader pod is ready.
  # https://docs.kics.io/latest/queries/kubernetes-queries/5744cbb8-5946-4b75-a196-ade44449525b/
  - "5744cbb8-5946-4b75-a196-ade44449525b"

  # ===========================================================================
  # Kubernetes: Namespace and Resource Policies
  # ===========================================================================
  # ResourceQuota and LimitRange for the openemr namespace are applied by
  # scripts/deploy.sh at cluster bootstrap. These are not in k8s/ because
  # they contain cluster-specific values (node count, instance size).
  # ===========================================================================

  # Pod or Container Without ResourceQuota
  # Applies to: all resources in openemr namespace
  # https://docs.kics.io/latest/queries/kubernetes-queries/48a5beba-e4c0-4584-a2aa-e6894e4cf424/
  - "48a5beba-e4c0-4584-a2aa-e6894e4cf424"

  # Pod or Container Without LimitRange
  # Applies to: all resources in openemr namespace
  # https://docs.kics.io/latest/queries/kubernetes-queries/4a20ebac-1060-4c81-95d1-1f7f620e983b/
  - "4a20ebac-1060-4c81-95d1-1f7f620e983b"

  # Ensure Administrative Boundaries Between Resources
  # Applies to: credential-rotation CronJob
  # Reason: all workloads target the openemr namespace; RBAC enforces boundaries
  # https://docs.kics.io/latest/queries/kubernetes-queries/e84eaf4d-2f45-47b2-abe8-e581b06deb66/
  - "e84eaf4d-2f45-47b2-abe8-e581b06deb66"

  # Service With External Load Balancer
  # Applies to: k8s/service.yaml (NLB, internet-facing)
  # Reason: NLB is the intended ingress path. L7 protection is provided by
  # AWS WAF attached to CloudFront (when enabled) or security group rules
  # restricting source IPs. TLS termination at NLB or pass-through to pods.
  # https://docs.kics.io/latest/queries/kubernetes-queries/26763a1c-5dda-4772-b507-5fca7fb5f165/
  - "26763a1c-5dda-4772-b507-5fca7fb5f165"

  # ===========================================================================
  # Terraform: AWS Infrastructure
  # ===========================================================================

  # S3 Bucket Logging Disabled
  # Applies to: alb-logs, cloudtrail-logs (log destinations — logging would
  # recurse), loki/tempo/mimir/alertmanager-storage (observability stores
  # with IAM-scoped access, not user data)
  # https://docs.kics.io/latest/queries/terraform-queries/aws/f861041c-8c9f-4156-acfc-5e6e524f5884/
  - "f861041c-8c9f-4156-acfc-5e6e524f5884"

  # S3 Bucket Without Versioning
  # Applies to: waf-logs bucket (ephemeral log data, not source of truth)
  # https://docs.kics.io/latest/queries/terraform-queries/aws/568a4d22-3517-44a6-a7ad-6a7eed88722c/
  - "568a4d22-3517-44a6-a7ad-6a7eed88722c"

  # CloudTrail Log Files S3 Bucket with Logging Disabled
  # Applies to: terraform/cloudtrail.tf — the bucket IS the log destination
  # https://docs.kics.io/latest/queries/terraform-queries/aws/ee9e50e8-b2ed-4176-ad42-8fc0cf7593f4/
  - "ee9e50e8-b2ed-4176-ad42-8fc0cf7593f4"

  # CloudTrail SNS Topic Name Undefined
  # Applies to: terraform/cloudtrail.tf
  # Reason: alerting is handled by the optional Prometheus/AlertManager
  # monitoring stack (scripts/install-monitoring.sh, 218+ alert rules)
  # https://docs.kics.io/latest/queries/terraform-queries/aws/482b7d26-0bdb-4b5f-bf6f-545826c0a3dd/
  - "482b7d26-0bdb-4b5f-bf6f-545826c0a3dd"

  # CloudTrail Not Integrated With CloudWatch
  # Applies to: terraform/cloudtrail.tf
  # Reason: CloudTrail logs to encrypted S3; CloudWatch integration deferred
  # to monitoring stack. Logs are retained with versioning + lifecycle rules.
  # https://docs.kics.io/latest/queries/terraform-queries/aws/17b30f8f-8dfb-4597-adf6-57600b6cf25e/
  - "17b30f8f-8dfb-4597-adf6-57600b6cf25e"

  # VPC Subnet Assigns Public IP
  # Applies to: terraform/vpc.tf public subnets
  # Reason: public subnets with auto-assign public IP are required for
  # internet-facing NLB and outbound traffic. Private subnets route through
  # NAT gateway. Nodes and pods are protected by security groups.
  # https://docs.kics.io/latest/queries/terraform-queries/aws/52f04a44-6bfa-4c41-b1d3-4ae99a2de05c/
  - "52f04a44-6bfa-4c41-b1d3-4ae99a2de05c"

  # Sensitive Port Is Exposed To Wide Private Network
  # Applies to: terraform/rds.tf (MySQL 3306 open to VPC CIDR)
  # Reason: RDS is in a private subnet within a dedicated VPC. VPC-wide
  # CIDR access is intentional to allow future workloads (monitoring,
  # analytics) to connect without SG changes. No public route exists.
  # https://docs.kics.io/latest/queries/terraform-queries/aws/92fe237e-074c-4262-81a4-2077acb928c1/
  - "92fe237e-074c-4262-81a4-2077acb928c1"

  # IAM Access Analyzer Not Enabled
  # Applies to: all Terraform resources (account-level check)
  # Reason: IAM Access Analyzer is an account-level service, not per-stack.
  # It should be enabled in the AWS account baseline (Organizations/Control
  # Tower). This Terraform stack manages only the EKS workload resources.
  # https://docs.kics.io/latest/queries/terraform-queries/aws/e592a0c5-5bdb-414c-9066-5dba7cdea370/
  - "e592a0c5-5bdb-414c-9066-5dba7cdea370"

  # ===========================================================================
  # Passwords and Secrets (False Positives)
  # ===========================================================================
  # KICS regex-based detection cannot resolve Terraform expressions or
  # distinguish OIDC permission scopes from secret values. Flagged files:
  # - terraform/credential-rotation.tf: "PLACEHOLDER_SEEDED_BY_DEPLOY_SCRIPT"
  #   (overwritten at apply time; lifecycle { ignore_changes } prevents drift)
  # - terraform/rds.tf: random_password.db_password.result (TF resource ref)
  # - monthly-version-check.yml: id-token: write (GitHub OIDC permission)
  # ===========================================================================

  # Passwords And Secrets
  # https://docs.kics.io/latest/queries/common-queries/a88baa34-e2ad-44ea-ad6f-8cac87bc7c71/
  - "a88baa34-e2ad-44ea-ad6f-8cac87bc7c71"

  # ===========================================================================
  # CI/CD: GitHub Actions
  # ===========================================================================
  # Actions are pinned to version tags from verified publishers (e.g.
  # actions/checkout@v6.0.2, hashicorp/setup-terraform@v4.0.0). Full SHA
  # pinning is not used because it reduces visibility.
  # ===========================================================================

  # Unpinned Actions Full Length Commit SHA
  # Applies to: all workflow files
  # https://docs.kics.io/latest/queries/cicd-queries/555ab8f9-2001-455e-a077-f2d0f41e2fb9/
  - "555ab8f9-2001-455e-a077-f2d0f41e2fb9"

  # ===========================================================================
  # Dockerfile Exceptions
  # ===========================================================================
  # Applies to: warp/Dockerfile, tools/credential-rotation/Dockerfile
  # Both are batch job containers (K8s Job), not long-running services.
  # Kubernetes monitors Job completion status; HEALTHCHECK is not applicable.
  # ===========================================================================

  # Apt Get Install Pin Version Not Defined
  # Applies to: warp/Dockerfile (gcc from python:3.14-slim base)
  # Reason: available gcc version depends on the Debian release bundled in
  # the base image; pinning would break across base image updates. Base
  # image tag is pinned; Trivy scans for CVEs on every push.
  # https://docs.kics.io/latest/queries/dockerfile-queries/965a08d7-ef86-4f14-8792-4a3b2098937e/
  - "965a08d7-ef86-4f14-8792-4a3b2098937e"

  # Unpinned Package Version in Pip Install
  # Applies to: warp/Dockerfile (pip, setuptools, wheel)
  # Reason: these are build tools upgraded to latest for security fixes; app
  # dependencies are pinned in requirements.txt
  # https://docs.kics.io/latest/queries/dockerfile-queries/02d9c71f-3ee8-4986-9c27-1a20d0d19bfc/
  - "02d9c71f-3ee8-4986-9c27-1a20d0d19bfc"

  # Healthcheck Instruction Missing
  # Applies to: warp/Dockerfile, tools/credential-rotation/Dockerfile
  # Reason: batch job containers — K8s Job controller monitors completion
  # https://docs.kics.io/latest/queries/dockerfile-queries/b03a748a-542d-44f4-bb86-9199ab4fd2d5/
  - "b03a748a-542d-44f4-bb86-9199ab4fd2d5"

  # Multiple RUN, ADD, COPY Instructions Listed
  # Applies to: warp/Dockerfile
  # Reason: separate COPY for requirements.txt vs source code is intentional
  # for Docker layer caching — dependency layer rebuilds only when
  # requirements.txt changes, not on every code change
  # https://docs.kics.io/latest/queries/dockerfile-queries/0008c003-79aa-42d8-95b8-1c2fe37dbfe6/
  - "0008c003-79aa-42d8-95b8-1c2fe37dbfe6"
