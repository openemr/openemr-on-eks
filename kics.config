# =============================================================================
# KICS Configuration File
# =============================================================================
# This configuration defines exclusions for the KICS (Keeping Infrastructure
# as Code Secure) scanner. Only verified false positives and intentional
# configurations with documented compensating controls are excluded.
#
# Policy: ZERO-TOLERANCE with documented exceptions only.
# All entries must be reviewed and approved by the security team.
#
# Documentation: https://docs.kics.io/latest/configuration-file/
# =============================================================================

exclude-queries:

  # ===========================================================================
  # Kubernetes Security Context Exceptions
  # ===========================================================================
  # OpenEMR Docker image requires root user and privilege escalation for
  # Apache/PHP-FPM process management. This is an upstream image requirement.
  # Compensating controls: minimal capabilities, RuntimeDefault seccomp,
  # dedicated namespace with RBAC, network policies restrict egress.
  # ===========================================================================

  # Privilege Escalation Allowed
  # Reason: OpenEMR needs SETUID/SETGID capabilities for Apache/PHP startup
  # https://docs.kics.io/latest/queries/kubernetes-queries/5572cc5e-1e4c-4113-92a6-7a8a3bd25e6d/
  - "5572cc5e-1e4c-4113-92a6-7a8a3bd25e6d"

  # Volume Mount With OS Directory Write Permissions
  # Reason: EFS-backed PVCs mounted to /etc/ssl and /etc/letsencrypt for
  #   TLS certificate management — these are NOT host filesystem mounts
  # https://docs.kics.io/latest/queries/kubernetes-queries/b7652612-de4e-4466-a0bf-1cd81f0c6063/
  - "b7652612-de4e-4466-a0bf-1cd81f0c6063"

  # No Drop Capabilities for Containers
  # Reason: Warp batch jobs install system packages at runtime (apt-get, pip)
  #   and require default capabilities to do so
  # https://docs.kics.io/latest/queries/kubernetes-queries/268ca686-7fb7-4ae9-b129-955a2a89064e/
  - "268ca686-7fb7-4ae9-b129-955a2a89064e"

  # ===========================================================================
  # HostPath Volume Exceptions (Fluent Bit Sidecar)
  # ===========================================================================
  # Fluent Bit sidecar mounts /proc and /sys (read-only) for the
  # node_exporter_metrics plugin to collect CPU, memory, and disk metrics.
  # Compensating controls: readOnly: true, allowPrivilegeEscalation: false,
  # no SYS_ADMIN capability (only DAC_READ_SEARCH), restricted egress.
  # ===========================================================================

  # Non Kube System Pod With Host Mount
  # https://docs.kics.io/latest/queries/kubernetes-queries/aa8f7a35-9923-4cad-bd61-a19b7f6aac91/
  - "aa8f7a35-9923-4cad-bd61-a19b7f6aac91"

  # ===========================================================================
  # Passwords and Secrets (False Positives)
  # ===========================================================================
  # KICS regex-based detection flags Terraform resource references and GitHub
  # OIDC permissions as hardcoded secrets. All flagged instances are safe:
  #   - terraform/credential-rotation.tf: Placeholder strings overwritten by
  #     deploy script; lifecycle { ignore_changes } prevents drift
  #   - terraform/rds.tf: random_password resource reference, not a literal
  #   - monthly-version-check.yml: id-token: write is an OIDC permission scope
  # ===========================================================================

  # Passwords And Secrets
  # https://docs.kics.io/latest/queries/common-queries/a88baa34-e2ad-44ea-ad6f-8cac87bc7c71/
  - "a88baa34-e2ad-44ea-ad6f-8cac87bc7c71"